{
  "name": "数据库查询MCP服务",
  "version": "1.0.0",
  "description": "一个通过Model Context Protocol提供MySQL数据库查询功能的服务",
  "transports": ["stdio"],
  "capabilities": {
    "tools": {
      "enabled": true
    },
    "resources": {
      "enabled": false
    },
    "prompts": {
      "enabled": false
    },
    "logging": {
      "enabled": true,
      "level": "info"
    }
  },
  "tools": [
    {
      "name": "query_database",
      "description": "执行MySQL数据库查询",
      "inputSchema": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "description": "数据库主机地址"
          },
          "port": {
            "type": "integer",
            "description": "数据库端口"
          },
          "user": {
            "type": "string",
            "description": "数据库用户名"
          },
          "pwd": {
            "type": "string",
            "description": "数据库密码"
          },
          "db": {
            "type": "string",
            "description": "数据库名称"
          },
          "querySql": {
            "type": "string",
            "description": "要执行的SQL查询语句"
          }
        },
        "required": ["host", "port", "user", "pwd", "db", "querySql"]
      }
    }
  ],
  "instructions": "这是一个数据库查询服务。用户可以使用query_database工具连接MySQL数据库并执行SQL查询。请确保提供完整的连接参数和有效的SQL查询语句。",
  "environmentVariables": [
    {
      "name": "DB_HOST",
      "description": "默认数据库主机地址",
      "required": false
    },
    {
      "name": "DB_PORT",
      "description": "默认数据库端口",
      "required": false
    },
    {
      "name": "DB_USER",
      "description": "默认数据库用户名",
      "required": false
    },
    {
      "name": "DB_PASSWORD",
      "description": "默认数据库密码",
      "required": false
    },
    {
      "name": "DB_NAME",
      "description": "默认数据库名称",
      "required": false
    }
  ]
}